# Server
PORT=5000
NODE_ENV=development

# Local dev without Atlas: set to true (uses persistent in-memory MongoDB at server/.mongodb-data)
USE_MEMORY_DB=true

# PRODUCTION (Render): set USE_MEMORY_DB=false and provide MongoDB Atlas URI
# Without Atlas, user accounts are LOST on every server restart!
# MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/skyrovix

# MongoDB Atlas or local mongod (used when USE_MEMORY_DB=false)
MONGO_URI=mongodb://localhost:27017/skyrovix

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_another_long_random_string_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Client (for CORS + email links)
CLIENT_URL=http://localhost:5173

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Nodemailer (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="skyrovix <no-reply@skyrovix.example.com>"

# Company / Brand (used in PDFs)
COMPANY_NAME=skyrovix
COMPANY_WEBSITE=https://skyrovix.example.com
COMPANY_EMAIL=skyrovix@gmail.com
COMPANY_ADDRESS=Remote · Global
